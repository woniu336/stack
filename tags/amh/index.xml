&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> rewrite ^/topic/index&lt;span class="o">(&lt;/span>.+?&lt;span class="o">)&lt;/span>&lt;span class="se">\.&lt;/span>html$ /topic/index.php?&lt;span class="nv">$1&lt;/span> last&lt;span class="p">;&lt;/span>

&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="nv">APP_KEY&lt;/span>&lt;span class="o">=&lt;/span>base64:rKwRuI6eRpCw/9e2XZKKGj/Yx3iZy5e7+FQ6+aQl8Zg&lt;span class="o">=&lt;/span>
